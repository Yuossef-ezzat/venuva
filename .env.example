# ===== LOGGING CONFIGURATION =====
# File path for application logs
LOGGING_FILE_NAME=E:/Logs/venuva.log

# Maximum file size before log rotation (e.g., 10MB)
LOGGING_MAX_FILE_SIZE=10MB

# Maximum number of history log files to keep
LOGGING_MAX_HISTORY=30

# Log file name pattern for rolling policy
LOGGING_FILE_NAME_PATTERN=D:/Logs/venuva-%d{yyyy-MM-dd}.%i.log

# ===== APPLICATION LOGGING LEVELS =====
# Logging level for the Venuva application (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_VENUVA=DEBUG

# Logging level for Spring Security
LOGGING_LEVEL_SECURITY=INFO

# Logging level for Hibernate SQL
LOGGING_LEVEL_HIBERNATE=DEBUG
