# ==============================================================================
# VENUVA APPLICATION - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================================================
# Copy this file to .env in the project root and fill in your actual values
# This file should NEVER be committed to version control
# Add .env to your .gitignore file
# ==============================================================================

# ===== SERVER CONFIGURATION =====
# The port on which the Spring Boot application will run (default: 8088)
SERVER_PORT=8088

# ===== DATABASE CONFIGURATION =====
# MySQL Database connection string
# Format: jdbc:mysql://host:port/database_name
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/venuvadbtwo

# Database username for authentication
SPRING_DATASOURCE_USERNAME=root

# Database password (leave empty if no password)
SPRING_DATASOURCE_PASSWORD=

# ===== JWT (JSON Web Token) CONFIGURATION =====
# Secret key used to sign JWT tokens - use a strong, random string in production
# Can be generated using: openssl rand -base64 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# JWT access token expiration time in milliseconds (100000 ms = ~1.67 minutes)
JWT_EXPIRATION=100000

# JWT refresh token expiration time in milliseconds (604800000 ms = 7 days)
JWT_REFRESH_EXPIRATION=604800000

# ===== EMAIL CONFIGURATION (Gmail SMTP) =====
# SMTP server host for sending emails
SPRING_MAIL_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SPRING_MAIL_PORT=587

# Gmail account email address
# Note: Use an App Password, not your regular Gmail password
# Generate App Password: https://myaccount.google.com/apppasswords
SPRING_MAIL_USERNAME=Waselny615@gmail.com

# Gmail App Password (NOT your regular password)
SPRING_MAIL_PASSWORD=uhnp sryl muzi bqiy

# Enable SMTP authentication
SPRING_MAIL_SMTP_AUTH=true

# Enable STARTTLS for secure connection
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

